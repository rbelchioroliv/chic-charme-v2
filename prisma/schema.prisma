generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Float
  category    String
  imageUrl    String   // Guardará o caminho da imagem (/uploads/nome-da-foto.jpg)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}